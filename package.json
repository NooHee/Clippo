{
  "name": "clipstack",
  "version": "0.1.0",
  "description": "Clipboard history manager for macOS",
  "main": "dist/main/main/index.js",
  "scripts": {
    "bump-version": "node scripts/bump-version.js",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run bump-version && npm run build:main && npm run build:renderer",
    "dev": "concurrently -k \"vite\" \"npm run build:main && wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.clipstack.app",
    "productName": "ClipStack",
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Install ClipStack",
      "background": null,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "i18next": "^26.0.4",
    "lucide-react": "^1.8.0",
    "react-i18next": "^17.0.2"
  }
}
